\f9\u-10178?\u-8722?\f6  \f0 Simple GUI Calculator (Python + Tkinter): \par
\par
import tkinter as tk\par
\par
# Create main window\par
root = tk.Tk()\par
root.title("Simple Calculator")\par
root.geometry("300x400")\par
\par
# Input field\par
expression = ""\par
\par
input_text = tk.StringVar()\par
\par
input_frame = tk.Frame(root)\par
input_frame.pack()\par
\par
input_field = tk.Entry(input_frame, textvariable=input_text, font=('arial', 18), bd=10, insertwidth=2, width=14, borderwidth=4)\par
input_field.grid(row=0, column=0)\par
input_field.pack(ipady=10)\par
\par
# Function to update input field\par
def press(num):\par
    global expression\par
    expression = expression + str(num)\par
    input_text.set(expression)\par
\par
# Function to evaluate expression\par
def equalpress():\par
    global expression\par
    try:\par
        total = str(eval(expression))\par
        input_text.set(total)\par
        expression = total\par
    except:\par
        input_text.set("Error")\par
        expression = ""\par
\par
# Function to clear\par
def clear():\par
    global expression\par
    expression = ""\par
    input_text.set("")\par
\par
# Buttons layout\par
button_frame = tk.Frame(root)\par
button_frame.pack()\par
\par
buttons = [\par
    '7', '8', '9', '/',\par
    '4', '5', '6', '*',\par
    '1', '2', '3', '-',\par
    'C', '0', '=', '+'\par
]\par
\par
row = 0\par
col = 0\par
\par
for button in buttons:\par
    if button == "=":\par
        btn = tk.Button(button_frame, text=button, width=5, height=2,\par
                        command=equalpress)\par
    elif button == "C":\par
        btn = tk.Button(button_frame, text=button, width=5, height=2,\par
                        command=clear)\par
    else:\par
        btn = tk.Button(button_frame, text=button, width=5, height=2,\par
                        command=lambda x=button: press(x))\par
\par
    btn.grid(row=row, column=col)\par
    col += 1\par
    if col > 3:\par
        col = 0\par
        row += 1\par
\par
# Run application\par
root.mainloop()\par
